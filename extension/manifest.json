{
  "manifest_version": 3,
  "name": "Lead Scraper Pro - Universal Business Lead Finder",
  "version": "1.0.0",
  "description": "Intelligent B2B lead finder extension that dynamically scrapes leads on any directory platform.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lead Scraper Pro"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "xlsx.full.min.js",
        "libs/fuse.js",
        "libs/papaparse.js",
        "content-main.js",
        "src/scraper/universalScraper.js",
        "src/scraper/smartDetector.js",
        "src/scraper/relevanceEngine.js",
        "src/scraper/keywordValidator.js",
        "src/scraper/infiniteScrollManager.js",
        "src/scraper/queueManager.js",
        "src/scraper/extractionFallback.js",
        "src/matcher/fuzzyMatcher.js",
        "src/matcher/synonymEngine.js",
        "src/export/csvExport.js",
        "src/export/excelExport.js",
        "src/testing/autoTester.js",
        "src/testing/debugLogger.js",
        "src/utils/regex.js",
        "src/utils/dedupe.js",
        "src/utils/domHelpers.js",
        "src/utils/scoring.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
